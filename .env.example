# Example environment variables for local development
# Copy this file to `.env` and fill in your real credentials.
# Do NOT commit your real `.env` to version control.

# MongoDB connection string (Atlas recommended string):
# e.g.
# MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# If your environment blocks DNS SRV lookups, get the standard (non-SRV) connection string
# from your Atlas cluster connection options and set it here instead.
